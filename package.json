{
  "name": "kempo-server",
  "type": "module",
  "version": "2.1.2",
  "description": "A lightweight, zero-dependency, file based routing server.",
  "exports": {
    "./rescan": "./dist/rescan.js",
    "./utils/cli": "./dist/utils/cli.js",
    "./utils/fs-utils": "./dist/utils/fs-utils.js"
  },
  "bin": {
    "kempo-server": "./dist/index.js"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "docs": "node dist/index.js -r ./docs",
    "spa": "node dist/index.js -r ./spa",
    "test": "npx kempo-test",
    "test:gui": "npx kempo-test --gui",
    "test:browser": "npx kempo-test -b",
    "test:node": "npx kempo-test -n"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "kempo-testing-framework": "^1.4.4",
    "terser": "^5.43.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dustinpoissant/kempo-server"
  }
}
